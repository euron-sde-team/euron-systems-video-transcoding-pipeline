{
  "_comment": "Per-environment orchestrator Lambda role policy. Substitute <ACCOUNT_ID> and <WORKER_ROLE_NAME> (e.g. euron-vod-worker-dev-role). iam:PassRole is scoped to that worker role so the Lambda can launch workers with it but nothing else.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ScaleUpWorkers",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateFleet",
        "ec2:RunInstances",
        "ec2:DescribeInstances",
        "ec2:CreateTags"
      ],
      "Resource": "*"
    },
    {
      "Sid": "PassWorkerRole",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": "arn:aws:iam::<ACCOUNT_ID>:role/<WORKER_ROLE_NAME>"
    },
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "*"
    },
    {
      "Sid": "VpcForRdsAccess",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateNetworkInterface",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DeleteNetworkInterface"
      ],
      "Resource": "*"
    }
  ]
}
