# ─────────────────────────────────────────────────────────────────────────────
# Euron Video Transcoding Pipeline, environment template
# Copy to .env and fill in. (Standalone phase: developer adds real creds.)
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4020

# ─── Postgres (DEDICATED database for this service) ──────────────────────────
# Prefer the RDS Proxy endpoint in production for connection pooling.
PG_DATABASE_HOST=localhost
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=postgres
PG_DATABASE_PORT=5432
PG_DATABASE=euron_video_pipeline
# Runtime PREFERS DATABASE_URL when set (the worker + orchestrator both use it); the PG_* vars above
# are the fallback when DATABASE_URL is empty. prisma generate also reads DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/euron_video_pipeline

# Pool sizing (per cluster worker). Workers (transcoders) should keep this small (2-4).
PG_POOL_MAX=8
PG_POOL_MIN=0
PG_CONNECTION_TIMEOUT=15000
PG_IDLE_TIMEOUT=10000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Management API (uploads / complete / list / retry), service-to-service shared secret.
SERVICE_API_KEY=change-me-service-key
# Playback tokens (short-TTL JWTs for the key/manifest endpoints). HS256 shared secret.
PLAYBACK_TOKEN_SECRET=change-me-playback-secret
# Default TTL (seconds) for minted playback tokens. Recommend short (<= 60s) for
# key-only fetches; longer is fine for a viewing session. Clamped to MAX at mint.
PLAYBACK_TOKEN_TTL_SECONDS=300
PLAYBACK_TOKEN_MAX_TTL_SECONDS=3600

# ─── AWS (raw uploads in S3, key wrapping in KMS, EC2 orchestration) ─────────
AWS_REGION=ap-south-1
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
UPLOAD_BUCKET=euron-uploads
MAX_UPLOAD_BYTES=21474836480
MAX_IN_FLIGHT=50
# KMS key for wrapping per-video content keys. Leave blank to use local AES wrapping (dev only).
KEY_KMS_KEY_ID=

# ─── Cloudflare R2 (processed output) + CDN ──────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=euron-vod
# S3-compatible endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Public CDN base for playback URLs, e.g. https://cdn.euron.one
R2_PUBLIC_BASE=

# ─── Orchestrator (Lambda), scale-up math + worker launch ───────────────────
MAX_WORKERS=20
DIVISOR=2
LAUNCH_TEMPLATE_NAME=transcoder
LAUNCH_TEMPLATE_VERSION=$Latest
WORKER_ROLE_TAG=transcoder
# The launch uses EC2 CreateFleet (type=instant), fanning out across EVERY subnet
# (one per AZ) x instance type so a single AZ's Spot pool running dry never blocks
# the fleet. Each (subnet,type) pair is a distinct capacity pool.
#   WORKER_SUBNET_IDS    csv of subnets, one per AZ (internet egress + DB reachable)
#   WORKER_INSTANCE_TYPES STRICT LADDER csv (highest preference first); each type is
#                         exhausted across all AZs before the next is tried, so bigger
#                         Graviton sizes are used when available and smaller ones only
#                         cover the shortfall. All must match the AMI arch (arm64 ->
#                         Graviton). Prefer 4xlarge for faster long-video transcodes.
# Both fall back to the legacy singletons (WORKER_SUBNET_ID / WORKER_INSTANCE_TYPE)
# when unset, so old single-AZ configs keep working.
WORKER_SUBNET_IDS=
WORKER_INSTANCE_TYPES=c7g.4xlarge,c7g.2xlarge,c7g.xlarge,c6g.xlarge,m7g.xlarge
WORKER_INSTANCE_TYPE=c7g.xlarge
WORKER_SUBNET_ID=
# Spot pool selection ("capacity-optimized" = deepest pool, fewest interruptions).
SPOT_ALLOCATION_STRATEGY=capacity-optimized
# Spot-ONLY by policy: NO On-Demand fallback. If no Spot pool has capacity the
# launch does nothing and the video stays queued until Spot returns (cron retries
# every minute). Set true ONLY if you want On-Demand to cover a Spot shortfall.
ONDEMAND_FALLBACK=false

# ─── Background-jobs pool (captions + MP4 download on smaller instances) ─────
# OPTIONAL second worker pool for decoupled background jobs. Whisper (captions) uses
# ~4 threads and the MP4 re-encode is async, so neither needs the big primary
# instances. When JOBS_LAUNCH_TEMPLATE_NAME is set, the orchestrator scales this pool
# independently from the video_jobs backlog (its own role tag + ladder + LT whose
# UserData sets WORKER_MODE=jobs); the primary LT then sets WORKER_MODE=primary.
# Leave JOBS_LAUNCH_TEMPLATE_NAME EMPTY for the legacy single pool (WORKER_MODE=all).
JOBS_LAUNCH_TEMPLATE_NAME=
JOBS_INSTANCE_TYPES=c7g.xlarge,c6g.xlarge,m7g.xlarge
JOBS_ROLE_TAG=transcoder-jobs
JOBS_MAX_WORKERS=50

# ─── Worker (EC2) ────────────────────────────────────────────────────────────
# Which queue(s) this worker services: "all" (default, legacy single pool: video
# then jobs), "primary" (videos only), or "jobs" (background jobs only). Set by each
# pool's launch-template UserData in a two-pool deployment.
WORKER_MODE=all
WORKER_ID=
IDLE_GRACE_MS=120000
POLL_MS=5000
HEARTBEAT_MS=30000
WHISPER_BIN=/opt/whisper.cpp/main
WHISPER_MODEL=/opt/models/ggml-small.bin
# Binary paths: the EC2 worker bootstrap overrides these to /usr/local/bin/* (where the AMI bakes
# them). For local dev on macOS use brew paths (e.g. /opt/homebrew/bin/ffmpeg) or leave them on PATH.
FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
SHAKA_PACKAGER_BIN=/usr/bin/packager
# Scratch dir. On the EC2 worker the bootstrap sets WORK_DIR=/mnt/work (EBS) AND exports
# TMPDIR=/mnt/work, so Shaka Packager's manifest temp file lands on the same filesystem as the output
# (a /tmp tmpfs makes the atomic rename fail with EXDEV / "generic:18"). See docs/TROUBLESHOOTING.md.
WORK_DIR=/tmp/euron-vod
# CFR TARGET frame rate for near-static sources. A slide deck with voiceover can
# carry an effective rate under 1 fps; passed through, the HLS output holds ~1 video
# frame per segment (avg_frame_rate=0/0) which hls.js/MSE cannot play. Only genuinely
# near-static sources (trigger floor is well below any real capture/broadcast rate,
# so NORMAL videos are never touched) are lifted to this constant rate via a
# per-output -r. Default 24.
MIN_OUTPUT_FPS=24
# Set to "false" on the worker AMI to actually run `shutdown -h now`. true = log only (local dev).
WORKER_DRY_RUN_SHUTDOWN=true
