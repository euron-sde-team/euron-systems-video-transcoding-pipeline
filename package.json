{
  "name": "euron-systems-video-transcoding-pipeline",
  "version": "0.1.0",
  "description": "Self-hosted VOD transcoding & delivery pipeline (FFmpeg + Shaka Packager + CMAF cbcs, Postgres-as-queue, EC2 Spot workers, Cloudflare R2). Standalone service.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc",
    "build:lambda": "esbuild src/orchestrator/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-lambda/index.js --external:@aws-sdk/*",
    "build:player": "esbuild player/src/index.ts --bundle --format=esm --target=es2020 --outfile=player/dist/euron-player.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "test": "vitest run"
  },
  "packageManager": "pnpm@9.0.0",
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-kms": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-presigned-post": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "express-xss-sanitizer": "^2.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.28.8",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "prisma": ">=6.16.0 <7.0.0",
    "prisma-kysely": "^2.2.1",
    "shaka-player": "^4.11.0",
    "ulid": "^2.3.0",
    "winston": "^3.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/express-xss-sanitizer": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.1",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^2.1.0"
  }
}
