generator kysely {
  provider     = "prisma-kysely"
  output       = "../src/db"
  enumFileName = "enums.ts"
  fileName     = "types.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model videos {
  id               String          @id
  tenant_id        String
  status           video_status    @default(uploading)
  stage            video_stage?
  progress         Int             @default(0) @db.SmallInt
  source_key       String?
  source_bytes     BigInt?
  output_prefix    String?
  output_bytes     BigInt?
  orientation      orientation?
  duration_seconds Int?
  protection       protection_mode @default(aes_128)
  watermark        watermark_mode  @default(dynamic_overlay)
  allow_offline    Boolean         @default(false)
  captions_langs   String[]        @default([])
  locked_by        String?
  locked_at        DateTime?       @db.Timestamptz(6)
  heartbeat_at     DateTime?       @db.Timestamptz(6)
  attempts         Int             @default(0)
  max_attempts     Int             @default(3)
  pipeline_config  Json            @default("{}")
  error            String?
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  ready_at         DateTime?       @db.Timestamptz(6)
  video_keys       video_keys?

  @@index([tenant_id, created_at])
}

model video_keys {
  id          String          @id
  video_id    String          @unique
  tenant_id   String
  kid_hex     String
  wrapped_key String
  wrap_scheme key_wrap_scheme @default(kms)
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  videos      videos          @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model addon_subscriptions {
  id                       String                    @id
  tenant_id                String
  addon_id                 String
  billing_cycle            billing_cycle             @default(MONTHLY)
  currency                 String
  original_price           Decimal                   @db.Decimal(10, 2)
  discount_applied         Decimal                   @default(0) @db.Decimal(10, 2)
  price_snapshot           Decimal                   @db.Decimal(10, 2)
  billing_provider_id      String?
  external_subscription_id String?
  started_at               DateTime                  @default(now())
  current_period_start     DateTime                  @default(now())
  current_period_end       DateTime
  cancelled_at             DateTime?
  status                   addon_subscription_status @default(PENDING)
  created_at               DateTime
  updated_at               DateTime
  billing_providers        billing_providers?        @relation(fields: [billing_provider_id], references: [id])
  tenant_addons            tenant_addons?

  @@index([addon_id])
  @@index([external_subscription_id])
  @@index([status])
  @@index([tenant_id])
}

model addons {
  id                         String          @id
  application_id             String
  code                       String          @unique
  name                       String
  description                String?
  product_id                 String
  grant_value                Int
  is_unlimited               Boolean         @default(false)
  price_monthly_inr          Decimal         @db.Decimal(10, 2)
  price_yearly_inr           Decimal         @db.Decimal(10, 2)
  discount_monthly_inr_type  discount_type   @default(NONE)
  discount_monthly_inr_value Decimal         @default(0) @db.Decimal(10, 2)
  discount_yearly_inr_type   discount_type   @default(NONE)
  discount_yearly_inr_value  Decimal         @default(0) @db.Decimal(10, 2)
  price_monthly_usd          Decimal         @db.Decimal(10, 2)
  price_yearly_usd           Decimal         @db.Decimal(10, 2)
  discount_monthly_usd_type  discount_type   @default(NONE)
  discount_monthly_usd_value Decimal         @default(0) @db.Decimal(10, 2)
  discount_yearly_usd_type   discount_type   @default(NONE)
  discount_yearly_usd_value  Decimal         @default(0) @db.Decimal(10, 2)
  is_active                  Boolean         @default(true)
  is_public                  Boolean         @default(true)
  sort_order                 Int             @default(0)
  created_at                 DateTime
  updated_at                 DateTime
  applications               applications    @relation(fields: [application_id], references: [id])
  products                   products        @relation(fields: [product_id], references: [id])
  tenant_addons              tenant_addons[]

  @@index([application_id])
  @@index([product_id])
}

model admin_audit_logs {
  id             String   @id
  actor_admin_id String?
  actor_email    String?
  actor_name     String?
  action         String
  category       String
  resource_id    String?
  resource_label String?
  tenant_id      String?
  summary        String
  metadata       Json?
  ip_address     String?
  user_agent     String?
  is_system      Boolean  @default(false)
  created_at     DateTime @default(now())
  device         String?
  browser        String?
  os             String?
  country        String?
  region         String?
  city           String?

  @@index([action])
  @@index([actor_admin_id])
  @@index([actor_admin_id, created_at], map: "admin_audit_logs_actor_idx")
  @@index([category])
  @@index([created_at])
  @@index([created_at], map: "admin_audit_logs_created_idx")
  @@index([tenant_id])
}

model admin_permissions {
  id                     String                   @id
  code                   String                   @unique
  name                   String
  description            String?
  category               String?
  created_at             DateTime
  admin_role_permissions admin_role_permissions[]

  @@index([category])
  @@index([code])
}

model admin_role_permissions {
  role_id           String
  permission_id     String
  created_at        DateTime          @default(now())
  admin_permissions admin_permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  admin_roles       admin_roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id])
  @@index([role_id])
}

model admin_roles {
  id                     String                   @id
  code                   String                   @unique
  name                   String
  description            String?
  is_system              Boolean                  @default(false)
  created_at             DateTime
  updated_at             DateTime
  admin_role_permissions admin_role_permissions[]
  admin_user_roles       admin_user_roles[]

  @@index([code])
}

model admin_user_roles {
  admin_user_id String
  role_id       String
  assigned_at   DateTime    @default(now())
  assigned_by   String?
  admin_users   admin_users @relation(fields: [admin_user_id], references: [id], onDelete: Cascade)
  admin_roles   admin_roles @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([admin_user_id, role_id])
  @@index([admin_user_id])
  @@index([role_id])
}

model admin_users {
  id                        String                      @id
  email                     String                      @unique
  password_hash             String?
  name                      String
  avatar_url                String?
  oauth_provider            String?
  oauth_provider_id         String?
  status                    admin_user_status           @default(ACTIVE)
  email_verified            Boolean                     @default(false)
  last_login_at             DateTime?
  created_at                DateTime
  updated_at                DateTime
  admin_user_roles          admin_user_roles[]
  partner_resources         partner_resources[]
  partners                  partners[]
  platform_blog_authors     platform_blog_authors[]
  tenant_addon_events       tenant_addon_events[]
  tenant_application_events tenant_application_events[]
  tenant_applications       tenant_applications[]

  @@unique([oauth_provider, oauth_provider_id])
  @@index([email])
  @@index([status])
}

model affiliate_clicks {
  id                  String         @id
  tenant_id           String
  affiliate_member_id String
  ip_address          String?
  user_agent          String?
  referrer            String?
  country             String?
  city                String?
  device              String?
  browser             String?
  os                  String?
  created_at          DateTime       @default(now())
  tenant_members      tenant_members @relation(fields: [affiliate_member_id], references: [id], onDelete: Cascade)
  tenants             tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, affiliate_member_id])
  @@index([tenant_id, created_at])
}

model affiliate_commissions {
  id                                                                       String                      @id
  tenant_id                                                                String
  order_id                                                                 String                      @unique
  affiliate_member_id                                                      String
  buyer_member_id                                                          String
  order_amount                                                             Decimal                     @db.Decimal(16, 2)
  commission_rate                                                          Decimal                     @db.Decimal(5, 2)
  commission_amount                                                        Decimal                     @db.Decimal(16, 2)
  currency                                                                 String
  status                                                                   affiliate_commission_status @default(COMPLETED)
  reversed_at                                                              DateTime?
  created_at                                                               DateTime                    @default(now())
  applied_fx_rate                                                          Decimal?                    @db.Decimal(18, 8)
  wallet_credit_amount                                                     Decimal?                    @db.Decimal(16, 2)
  wallet_credit_currency                                                   String?                     @db.VarChar(8)
  tenant_members_affiliate_commissions_affiliate_member_idTotenant_members tenant_members              @relation("affiliate_commissions_affiliate_member_idTotenant_members", fields: [affiliate_member_id], references: [id], onDelete: Cascade)
  tenant_members_affiliate_commissions_buyer_member_idTotenant_members     tenant_members              @relation("affiliate_commissions_buyer_member_idTotenant_members", fields: [buyer_member_id], references: [id], onDelete: Cascade)
  payment_orders                                                           payment_orders              @relation(fields: [order_id], references: [id], onDelete: Cascade)
  tenants                                                                  tenants                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, affiliate_member_id])
  @@index([tenant_id, created_at])
}

model affiliate_settings {
  id                     String   @id
  tenant_id              String   @unique
  global_commission_rate Decimal  @default(5) @db.Decimal(5, 2)
  min_withdrawal_amount  Decimal  @default(500) @db.Decimal(16, 2)
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime
  tenants                tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model affiliate_withdrawals {
  id                      String                      @id
  tenant_id               String
  tenant_member_id        String
  wallet_id               String
  amount                  Decimal                     @db.Decimal(16, 2)
  currency                String
  status                  affiliate_withdrawal_status @default(PENDING)
  payment_detail_type     member_payment_detail_type?
  payment_detail_snapshot Json?
  admin_notes             String?
  requested_at            DateTime                    @default(now())
  processed_by            String?
  processed_at            DateTime?
  rejected_reason         String?
  created_at              DateTime                    @default(now())
  updated_at              DateTime
  tenants                 tenants                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members          tenant_members              @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)
  member_wallets          member_wallets              @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, status])
  @@index([tenant_id, tenant_member_id])
}

model ai_api_chat_messages {
  id                   String               @id
  tenant_id            String
  session_id           String
  sender_type          String
  content              String?
  model_id             String?
  created_at           DateTime             @default(now())
  ai_api_chat_sessions ai_api_chat_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  tenants              tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([sender_type])
  @@index([tenant_id, session_id])
}

model ai_api_chat_sessions {
  id                   String                 @id
  tenant_id            String
  tenant_member_id     String
  title                String?                @default("New Chat")
  created_at           DateTime               @default(now())
  updated_at           DateTime
  ai_api_chat_messages ai_api_chat_messages[]
  tenants              tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members       tenant_members         @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, tenant_member_id])
}

model ai_api_keys {
  id               String         @id
  tenant_id        String
  tenant_member_id String
  key_hash         String
  key_prefix       String
  name             String?
  expires_at       DateTime
  created_at       DateTime       @default(now())
  tenants          tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members   tenant_members @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, key_hash])
  @@index([key_hash])
  @@index([tenant_id, tenant_member_id])
}

model ai_assistant_messages {
  id                    String                @id
  tenant_id             String
  session_id            String
  role                  ai_assistant_role
  content               String
  tools                 Json?
  created_at            DateTime              @default(now())
  ai_assistant_sessions ai_assistant_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  tenants               tenants               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, session_id])
}

model ai_assistant_sessions {
  id                    String                  @id
  tenant_id             String
  tenant_member_id      String
  title                 String                  @default("New Chat")
  created_at            DateTime                @default(now())
  updated_at            DateTime
  ai_assistant_messages ai_assistant_messages[]
  tenants               tenants                 @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members        tenant_members          @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, tenant_member_id])
}

model ai_custom_guardrails {
  id               String         @id
  tenant_id        String
  tenant_member_id String
  name             String
  description      String?
  type             String
  action           String
  pattern          String
  message          String
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())
  updated_at       DateTime
  tenants          tenants        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members   tenant_members @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, tenant_member_id])
  @@index([tenant_id, tenant_member_id, type, is_active])
}

model applications {
  id                  String                @id
  code                String                @unique
  name                String
  description         String?
  icon_url            String?
  is_active           Boolean               @default(true)
  is_public           Boolean               @default(true)
  sort_order          Int                   @default(0)
  created_at          DateTime
  updated_at          DateTime
  config              Json?
  addons              addons[]
  features            features[]
  plan_applications   plan_applications[]
  tenant_applications tenant_applications[]
}

model approval_workflow_config {
  id                String                 @id
  tenant_id         String                 @unique
  workflow_type     approval_workflow_type @default(SINGLE)
  escalation_amount Decimal?               @db.Decimal(15, 2)
  escalation_days   Int                    @default(5)
  created_at        DateTime
  updated_at        DateTime
  tenants           tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model assignment_evaluations {
  id                     String                 @id
  tenant_id              String
  submission_id          String                 @unique
  assignment_id          String
  tenant_member_id       String
  score                  Int
  max_score              Int                    @default(100)
  feedback               String?
  evaluated_by           String
  evaluated_at           DateTime
  created_at             DateTime
  updated_at             DateTime
  assignment_submissions assignment_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, assignment_id])
  @@index([tenant_id, submission_id])
  @@index([tenant_id, tenant_member_id])
}

model assignment_submissions {
  id                     String                  @id
  tenant_id              String
  assignment_id          String
  tenant_member_id       String
  course_id              String
  content_type           submission_content_type @default(TEXT)
  text_content           String?
  pdf_key                String?
  status                 submission_status       @default(SUBMITTED)
  submitted_at           DateTime?
  created_at             DateTime
  updated_at             DateTime
  assignment_evaluations assignment_evaluations?
  assignments            assignments             @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  courses                courses                 @relation(fields: [course_id], references: [id], onDelete: Cascade)
  tenant_members         tenant_members          @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, assignment_id, tenant_member_id])
  @@index([tenant_id, assignment_id])
  @@index([tenant_id, course_id])
  @@index([tenant_id, status])
  @@index([tenant_id, tenant_member_id])
}

model assignments {
  id                         String                       @id
  tenant_id                  String
  course_id                  String
  lesson_id                  String?
  title                      String
  instructions               String?
  resource_links             String[]                     @default([])
  created_at                 DateTime
  updated_at                 DateTime
  ai_generated               Boolean                      @default(false)
  content_type               assignment_content_type      @default(TEXT)
  due_date                   DateTime?
  max_score                  Int                          @default(100)
  pdf_key                    String?
  scope                      assignment_scope             @default(LESSON)
  section_id                 String?
  sort_order                 Int                          @default(0)
  source_lecture_id          String?
  status                     assignment_status            @default(DRAFT)
  assignment_submissions     assignment_submissions[]
  courses                    courses                      @relation(fields: [course_id], references: [id], onDelete: Cascade)
  course_lessons             course_lessons?              @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  course_sections            course_sections?             @relation(fields: [section_id], references: [id], onDelete: Cascade)
  member_assignment_progress member_assignment_progress[]

  @@index([tenant_id, course_id])
  @@index([tenant_id, course_id, status])
  @@index([tenant_id, lesson_id])
  @@index([tenant_id, section_id])
  @@index([tenant_id, status])
}

model avani_interview_analytics {
  id                           String           @id
  interview_id                 String           @unique
  tenant_id                    String
  tenant_member_id             String
  domain                       String?
  role                         String?
  file_type                    String?
  file_name                    String?
  file_size                    Int?
  total_rounds                 Int?
  total_questions              Int?
  questions_answered           Int              @default(0)
  average_domain_rating        Float?
  average_communication_rating Float?
  overall_rating               Float?
  interview_duration           Int?
  completed_at                 DateTime?
  metadata                     Json?
  created_at                   DateTime         @default(now())
  updated_at                   DateTime
  avani_interviews             avani_interviews @relation(fields: [interview_id], references: [id], onDelete: Cascade)
  tenants                      tenants          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members               tenant_members   @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, tenant_member_id])
}

model avani_interviews {
  id                        String                     @id
  tenant_id                 String
  tenant_member_id          String
  domain                    String?
  role                      String?
  company_name              String?
  source_type               avani_interview_source     @default(RESUME)
  resume_summary            String?
  job_description_summary   String?
  questions                 Json[]
  status                    avani_interview_status     @default(IN_PROGRESS)
  created_at                DateTime                   @default(now())
  updated_at                DateTime
  avani_interview_analytics avani_interview_analytics?
  tenants                   tenants                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members            tenant_members             @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, tenant_member_id])
}

model batch_enrollments {
  id               String            @id
  tenant_id        String
  batch_id         String
  tenant_member_id String
  joined_at        DateTime          @default(now())
  valid_till       DateTime?
  status           enrollment_status @default(ACTIVE)
  source           enrollment_source @default(PURCHASED)
  source_order_id  String?
  source_coupon_id String?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @default(now())
  batches          batches           @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  tenants          tenants           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_members   tenant_members    @relation(fields: [tenant_member_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, batch_id, tenant_member_id])
  @@index([batch_id, status])
  @@index([tenant_id, status])
  @@index([tenant_id, tenant_member_id])
}

model batch_items {
  id         String          @id
  tenant_id  String
  batch_id   String
  item_type  batch_item_type
  course_id  String?
  book_id    String?
  sort_order Int             @default(0)
  created_at DateTime        @default(now())
  batches    batches         @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  books      books?          @relation(fields: [book_id], references: [id], onDelete: Cascade)
  courses    courses?        @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, batch_id, book_id])
  @@unique([tenant_id, batch_id, course_id])
  @@index([tenant_id, batch_id])
  @@index([tenant_id, book_id])
  @@index([tenant_id, course_id])
}

model batch_leaderboard_snapshots {
  id           String   @id
  tenant_id    String
  batch_id     String
  computed_at  DateTime @default(now())
  participants Int      @default(0)
  payload      Json
  created_at   DateTime @default(now())
  batches      batches  @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  tenants      tenants  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, batch_id, computed_at])
}

model batch_session_schedules {
  id                    String                        @id
  tenant_id             String
  batch_id              String
  course_id             String
  lecture_id            String?
  title                 String
  description           String?
  days_of_week          String[]                      @default([])
  time_of_day           String                        @db.VarChar(5)
  duration_minutes      Int
  timezone              String                        @db.VarChar(64)
  recurrence_start_date DateTime
  recurrence_end_date   DateTime
  instructor_id         String?
  status                batch_session_schedule_status @default(ACTIVE)
  last_materialized_at  DateTime?
  total_generated       Int                           @default(0)
  created_at            DateTime                      @default(now())
  updated_at            DateTime                      @default(now())
  batches               batches                       @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  courses               courses                       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lectures              lectures?                     @relation(fields: [lecture_id], references: [id])
  tenants               tenants                       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  live_sessions         live_sessions[]

  @@index([tenant_id, batch_id])
  @@index([tenant_id, course_id])
  @@index([tenant_id, status, recurrence_end_date])
}

model batches {
  id                          String                        @id
  tenant_id                   String
  title                       String
  slug                        String
  subtitle                    String?
  description                 String?
  thumbnail_url               String?
  cover_image_url             String?
  preview_url                 String?
  start_date                  DateTime
  end_date                    DateTime?
  enrollment_open_date        DateTime?
  enrollment_close_date       DateTime?
  duration_days               Int?
  validity_days               Int?
  price_inr                   Decimal?                      @db.Decimal(10, 2)
  price_usd                   Decimal?                      @db.Decimal(10, 2)
  discount_inr                Decimal?                      @db.Decimal(10, 2)
  discount_usd                Decimal?                      @db.Decimal(10, 2)
