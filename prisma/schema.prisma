model test_attempt_answers {
  id                String         @id
  tenant_id         String
  attempt_id        String
  question_id       String
  answer            Json?
  time_spent_sec    Int            @default(0)
  marked_for_review Boolean        @default(false)
  is_correct        Boolean?
  marks_awarded     Decimal?       @db.Decimal(6, 2)
  created_at        DateTime       @default(now())
  updated_at        DateTime
  test_attempts     test_attempts  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  test_questions    test_questions @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([attempt_id, question_id])
  @@index([tenant_id, attempt_id])
}

model test_attempt_modules {
  id                String                     @id
  tenant_id         String
  attempt_id        String
  module_id         String
  section_id        String
  stage_no          Int
  variant           String
  order_index       Int
  status            test_attempt_module_status @default(PENDING)
  question_ids      String[]                   @default([])
  pretest_ids       String[]                   @default([])
  time_limit_sec    Int
  started_at        DateTime?
  completed_at      DateTime?
  raw_correct       Int?
  raw_score         Decimal?                   @db.Decimal(8, 2)
  routed_to_variant String?
  auto_completed    Boolean                    @default(false)
  created_at        DateTime                   @default(now())
  updated_at        DateTime
  test_attempts     test_attempts              @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  test_modules      test_modules               @relation(fields: [module_id], references: [id], onDelete: Cascade)

  @@unique([attempt_id, module_id])
  @@index([tenant_id, attempt_id, order_index])
}

model test_attempts {
  id                   String                 @id
  tenant_id            String
  learner_id           String
  test_id              String
  test_series_id       String
  started_at           DateTime               @default(now())
  submitted_at         DateTime?
  time_remaining_sec   Int?
  status               test_attempt_status    @default(IN_PROGRESS)
  score                Decimal?               @db.Decimal(8, 2)
  percentage           Decimal?               @db.Decimal(5, 2)
  percentile           Decimal?               @db.Decimal(5, 2)
  rank                 Int?
  predicted_rank_min   Int?
  predicted_rank_max   Int?
  analytics            Json?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  question_ids         String[]               @default([])
  scaled_score         Decimal?               @db.Decimal(8, 2)
  scaled_score_max     Int?
  proctoring_flags     Json?
  tab_switch_count     Int                    @default(0)
  break_ends_at        DateTime?              @db.Timestamptz(6)
  test_attempt_answers test_attempt_answers[]
  test_attempt_modules test_attempt_modules[]
  tenant_members       tenant_members         @relation(fields: [learner_id], references: [id], onDelete: Cascade)
  tenants              tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tests                tests                  @relation(fields: [test_id], references: [id], onDelete: Cascade)
  test_series          test_series            @relation(fields: [test_series_id], references: [id], onDelete: Cascade)
  test_bookmarks       test_bookmarks[]

  @@index([tenant_id, learner_id])
  @@index([tenant_id, test_id, score])
  @@index([tenant_id, test_id, status])
  @@index([tenant_id, test_series_id])
}

model test_bookmarks {
  id             String         @id
